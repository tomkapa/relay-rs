# Relay configuration. Copy to `.env` and fill in.
#
# Provider is inferred from which `*_API_KEY` is set: set exactly one.
# Setting both is rejected at startup; setting neither is rejected at startup.

# --- OpenAI (or any OpenAI-Chat-Completions-compatible endpoint) ---
# Examples for OPENAI_BASE_URL:
#   https://api.openai.com/v1            (omit env var; this is the default)
#   https://api.deepseek.com/v1          (DeepSeek)
#   https://api.together.xyz/v1          (Together)
OPENAI_API_KEY=
# OPENAI_BASE_URL=

# --- Anthropic ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=

# --- Tools ---
# Brave Search API key for the `web_search` tool.
BRAVE_SEARCH_API_KEY=

# --- Model ---
# Provider-specific model id. Examples:
#   openai:     gpt-4o, gpt-5
#   deepseek:   deepseek-chat, deepseek-reasoner, deepseek-v4-flash
#   anthropic:  claude-sonnet-4-5, claude-opus-4-7
MODEL=claude-sonnet-4-5

# --- HTTP server ---
# Defaults to 127.0.0.1:8080.
# HTTP_ADDR=127.0.0.1:8080

# --- Auth / tenancy ---
# Every existing route except /auth/google/* and /healthz is gated behind a
# session cookie. The four required auth settings below — three secrets
# (RELAY_JWT_SECRET, GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET) plus the
# non-secret GOOGLE_REDIRECT_URL — are all REQUIRED at startup. The server
# fails fast with a `config::ConfigError` "missing field" error if any is
# unset.
#
# See doc/tenancy.md for the full architecture and the OAuth flow.
#
# HS256 signing key for the session JWT carried in the `relay_session`
# cookie. Must be at least 32 bytes of random material. Generate with:
#     openssl rand -hex 32
# Rotate to invalidate every active session (v1 has no per-session
# revocation list).
RELAY_JWT_SECRET=
#
# Google OAuth 2.0 client credentials. Create one at
#   https://console.cloud.google.com/apis/credentials
# (OAuth 2.0 Client ID, type "Web application") and register the
# `Authorized redirect URI` exactly as set in `GOOGLE_REDIRECT_URL` below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
#
# The callback URL Google redirects to after consent. Must match the
# value registered in the Google console. Local dev:
#   http://localhost:8080/auth/google/callback
# Production:
#   https://relay.example.com/auth/google/callback
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback
#
# Master Key Encryption Key for MCP server credentials. AES-256-GCM envelope
# encryption: HKDF-SHA256 derives a per-org KEK from this root key. Must be
# exactly 32 bytes, base64-encoded. Generate with:
#     openssl rand -base64 32
# Rotation: bump key_version in config, keep the old key alongside the new one;
# rows are re-encrypted lazily on write.
RELAY_MASTER_KEK=
#
# Public-facing base URL Relay tells MCP OAuth vendors to redirect back to.
# The MCP OAuth callback path (/mcp-oauth/callback) is appended at runtime.
# Local dev:   http://localhost:8080
# Production:  https://relay.example.com
RELAY_OAUTH_REDIRECT_BASE=http://localhost:8080
#
# Origin of the SPA. When the FE and BE share an origin (typical prod
# deploy: web bundle served by the BE), leave this unset and the
# post-OAuth-callback redirect stays a relative path. In split-origin
# dev (Bun web on 5173, Rust BE on 8080), set this so the BE prepends
# the FE origin to the callback redirect — otherwise the browser stays
# on the BE host and 404s on /connections/oauth-callback.
# Must be an http(s) origin with no path. The path stays operator-
# controlled; user-supplied `return_to` is still constrained to a
# relative path so this cannot be turned into an open redirect.
RELAY_WEB_BASE_URL=http://localhost:5173
#
# Whether to set the `Secure` attribute on the session cookie.
# Defaults to `true` (secure-by-default). Set to `false` ONLY for local
# http://localhost dev where the browser refuses Secure cookies over
# plain HTTP.
# RELAY_COOKIE_SECURE=false
#
# (Optional, future) Origin used to validate the `return_to` query
# parameter on /auth/google/login so the callback can't be turned into
# an open-redirect. Today the validation is "must start with /" — when
# this var is honoured, absolute URLs matching the origin will be
# allowed. Reserved.
# RELAY_PUBLIC_ORIGIN=http://localhost:8080

# --- Observability ---
# Each OTLP backend below is independently optional. With both unset, the
# server runs console-only (stderr) and a single `warn!` notes that OTLP
# export is disabled.
#
# `*_BASE_URL` values below take an OTLP base; the program appends `/v1/traces`
# automatically. Setting a full traces URL (path ending in `/v1/traces`) also
# works — it's left as-is.
#
# Honeycomb — application/HTTP/DB latency view.
# HONEYCOMB_API_KEY=
# HONEYCOMB_BASE_URL=https://api.honeycomb.io   # default; EU is api.eu1.honeycomb.io
# OTEL_LOG_LEVEL=relay_rs=debug,claudius=warn            # default for the OTel layer
# RELAY_GENAI_CAPTURE_CONTENT=0                          # 1 captures prompt/response content (DEBUG)
#
# Langfuse — agent/LLM workflow view. Requires both keys; auth is HTTP Basic.
# Default base targets US cloud. Other regions:
#   EU:         https://cloud.langfuse.com/api/public/otel
#   Japan:      https://jp.cloud.langfuse.com/api/public/otel
#   Self-host:  http://<host>:3000/api/public/otel
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=https://us.cloud.langfuse.com/api/public/otel   # default
