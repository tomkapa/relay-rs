meta {
  name: GET /agents — list agents
  type: http
  seq: 13
}

get {
  url: {{base_url}}/agents
  body: none
  auth: none
}

headers {
  Accept: application/json
}

docs {
  Returns every row, ordered by `created_at` ascending. Includes the
  always-present default agent (the row seeded at startup) plus any agents
  created via `POST /agents`.
}

tests {
  test("200 OK", function() {
    expect(res.status).to.equal(200);
  });

  test("at least one default agent exists", function() {
    const json = res.getBody();
    expect(json).to.be.an("array");
    const defaults = json.filter(a => a.is_default);
    expect(defaults.length).to.equal(1);
  });
}
