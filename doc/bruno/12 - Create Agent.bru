meta {
  name: POST /agents — create an agent
  type: http
  seq: 12
}

post {
  url: {{base_url}}/agents
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "name": "researcher",
    "system_prompt": "You are a careful researcher. You search before answering, you cite sources, and you flag uncertainty rather than guess.",
    "is_default": false
  }
}

docs {
  Mint a new agent. `is_default = true` atomically demotes the previously-
  default row in the same transaction, so the partial unique index
  `agents_default_unique` is always satisfied.

  The `agents` table is uncapped at the global level (relay-rs is SaaS;
  tenants accumulate agents over time). Per-tenant caps will land alongside
  auth.
}

script:post-response {
  const json = res.getBody();
  bru.setVar("created_agent_id", json.id);
}

tests {
  test("201 Created", function() {
    expect(res.status).to.equal(201);
  });

  test("id present", function() {
    const json = res.getBody();
    expect(json.id).to.be.a("string");
    expect(json.name).to.equal("researcher");
    expect(json.is_default).to.equal(false);
  });
}
