meta {
  name: PUT /agents/{id} — update an agent
  type: http
  seq: 4
}

put {
  url: {{base_url}}/agents/{{created_agent_id}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "system_prompt": "You are a careful researcher. v2: cite at least one source per claim."
  }
}

docs {
  Patch any subset of `name`, `system_prompt`, `is_default`. Omit a field to
  leave it unchanged.

  - `is_default = true` atomically demotes the previously-default row.
  - `is_default = false` against the current default returns 409 — the system
    requires exactly one default at all times, so promote another row first.
  - An update to `system_prompt` becomes visible to live workers within the
    cache TTL (60 s); there is no synchronous flush.
}

tests {
  test("200 OK", function() {
    expect(res.status).to.equal(200);
  });

  test("system_prompt updated", function() {
    const json = res.getBody();
    expect(json.system_prompt).to.contain("v2");
  });
}
